# Copy this file to .env and fill in your values.
# The simulators read these at startup — set them in your shell or via a .env loader.

# Databricks workspace URL (include https://)
DATABRICKS_HOST=https://<workspace-id>.azuredatabricks.net

# Service principal credentials
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<service-principal-secret>

# Zerobus ingest endpoint (include https://)
ZEROBUS_ENDPOINT=https://<workspace-id>.zerobus.<region>.azuredatabricks.net

# Optional: port for the simulator control UI (default: 7777)
# SIM_UI_PORT=7777
