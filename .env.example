# Copy to .env and fill in. Used for local `uvicorn` + simulator runs.

# Databricks workspace
DATABRICKS_HOST=https://YOUR-WORKSPACE.azuredatabricks.net

# Service principal (app-3dxwqo). Create a secret under the SP
# in the Admin console -> Service principals -> Secrets.
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Zerobus ingest endpoint (region-specific). Find under
#   Workspace -> Data Ingestion -> Zerobus -> Endpoint
ZEROBUS_ENDPOINT=YOUR-WORKSPACE.zerobus.REGION.azuredatabricks.net:443

# Lakebase Postgres (for local backend dev)
PGHOST=YOUR-INSTANCE.database.cloud.databricks.com
PGPORT=5432
PGDATABASE=databricks_postgres
PGUSER=YOUR-SERVICE-PRINCIPAL-UUID

# Unity Catalog
UC_CATALOG=livezerobus
UC_SCHEMA=procurement
